generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFFLINE
  INACTIVE
}

enum TruckStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  INACTIVE
}

enum TrailerStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  INACTIVE
}

enum CargoStatus {
  CREATED
  WAITING_PICKUP
  PICKED_UP
  IN_TRANSIT
  NEAR_DESTINATION
  DELIVERED
  CANCELLED
  INCIDENT
}

enum TripStatus {
  WAITING_APPOINTMENT
  APPOINTMENT_DONE
  LOADED
  DISPATCHED_ORIGIN
  AT_BORDER
  BORDER_CLEARED
  ARRIVED
  DISCHARGED
  // Só para carga CONTAINER: depois de descarregar, o container vazio tem de
  // ser devolvido ao dono/depósito antes da viagem fechar.
  CONTAINER_RETURN_PENDING
  CONTAINER_RETURNED
  CANCELLED
}

model Border {
  id          String       @id @default(uuid()) @db.Char(36)
  name        String       @unique @db.VarChar(100)
  countryA    String       @db.VarChar(80)
  countryB    String       @db.VarChar(80)
  lat         Decimal?     @db.Decimal(9, 6)
  lng         Decimal?     @db.Decimal(9, 6)
  isActive    Boolean      @default(true)
  tripBorders TripBorder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([name])
  @@map("borders")
}

// Ordered border crossings of a trip's route. arrivedAt/clearedAt are stamped
// as the driver reaches and clears each post (AT_BORDER / BORDER_CLEARED).
model TripBorder {
  id        String    @id @default(uuid()) @db.Char(36)
  tripId    String    @db.Char(36)
  borderId  String    @db.Char(36)
  sequence  Int
  arrivedAt DateTime?
  clearedAt DateTime?
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  border    Border    @relation(fields: [borderId], references: [id], onDelete: Restrict)

  @@unique([tripId, sequence])
  @@unique([tripId, borderId])
  @@index([borderId])
  @@map("trip_borders")
}

enum TripEventType {
  DISPATCHED_ORIGIN
  AT_BORDER
  BORDER_CLEARED
  ARRIVED
  DISCHARGED
  STATUS_CHANGE
}

enum IncidentType {
  ACCIDENT
  BREAKDOWN
  TRAFFIC
  ROAD_BLOCKED
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

model Role {
  id          String    @id @default(uuid()) @db.Char(36)
  name        String    @unique @db.VarChar(50)
  description String?   @db.VarChar(255)
  users       User[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([createdAt])
  @@map("roles")
}

model User {
  id            String         @id @default(uuid()) @db.Char(36)
  roleId        String         @db.Char(36)
  firstName     String         @db.VarChar(100)
  lastName      String         @db.VarChar(100)
  email         String         @unique @db.VarChar(150)
  password      String
  phone         String?        @db.VarChar(30)
  isActive      Boolean        @default(true)
  lastLogin     DateTime?
  clientId      String?        @db.Char(36)
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  driverProfile Driver?
  notifications Notification[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([roleId])
  @@index([email])
  @@index([isActive])
  @@index([clientId])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @db.Char(36)
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Client {
  id          String    @id @default(uuid()) @db.Char(36)
  companyName String    @db.VarChar(150)
  contactName String?   @db.VarChar(150)
  nuit        String?   @db.VarChar(30)
  phone       String?   @db.VarChar(30)
  email       String?   @db.VarChar(150)
  address     String?   @db.VarChar(255)
  city        String?   @db.VarChar(100)
  province    String?   @db.VarChar(100)
  country     String    @default("Moçambique") @db.VarChar(100)
  isActive    Boolean   @default(true)
  // Token público, persistente e opaco para partilhar TODAS as cargas do
  // cliente num único link (/track/client/:token). Regenerável para revogar.
  publicShareToken String @unique @default(uuid()) @db.Char(36)
  cargos      Cargo[]
  users       User[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([companyName])
  @@index([email])
  @@index([isActive])
  @@index([createdAt])
  @@map("clients")
}

model Driver {
  id             String       @id @default(uuid()) @db.Char(36)
  userId         String?      @unique @db.Char(36)
  fullName       String       @db.VarChar(150)
  licenseNumber  String       @unique @db.VarChar(80)
  passportNumber String?      @db.VarChar(30)
  phone          String?      @db.VarChar(30)
  email          String?      @db.VarChar(150)
  status         DriverStatus @default(AVAILABLE)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  trips          Trip[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([licenseNumber])
  @@index([status])
  @@index([createdAt])
  @@map("drivers")
}

model Truck {
  id          String      @id @default(uuid()) @db.Char(36)
  plateNumber String      @unique @db.VarChar(30)
  brand       String?     @db.VarChar(100)
  model       String?     @db.VarChar(100)
  year        Int?
  status      TruckStatus @default(AVAILABLE)
  trailers    Trailer[]
  trips       Trip[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([plateNumber])
  @@index([status])
  @@index([createdAt])
  @@map("trucks")
}

model Trailer {
  id          String        @id @default(uuid()) @db.Char(36)
  truckId     String?       @db.Char(36)
  plateNumber String        @unique @db.VarChar(30)
  brand       String?       @db.VarChar(100)
  model       String?       @db.VarChar(100)
  year        Int?
  tonnage     Decimal?      @db.Decimal(12, 3)
  status      TrailerStatus @default(AVAILABLE)
  truck       Truck?        @relation(fields: [truckId], references: [id], onDelete: SetNull)
  trips       Trip[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([truckId])
  @@index([plateNumber])
  @@index([status])
  @@index([createdAt])
  @@map("trailers")
}

enum CargoType {
  CONTAINER
  GRANEL
  GERAL
}

model Cargo {
  id               String      @id @default(uuid()) @db.Char(36)
  clientId         String      @db.Char(36)
  code             String      @unique @db.VarChar(80)
  description      String?     @db.VarChar(255)
  type             CargoType   @default(GRANEL)
  containerNumber  String?     @db.VarChar(40)
  weightTonnes     Decimal?    @db.Decimal(12, 3)
  volumeM3         Decimal?    @db.Decimal(12, 3)
  origin           String      @db.VarChar(150)
  destination      String      @db.VarChar(150)
  pickupDate       DateTime?
  expectedDelivery DateTime?
  status           CargoStatus @default(CREATED)
  observations     String?
  client           Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  trips            Trip[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  @@index([clientId])
  @@index([code])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("cargos")
}

model Trip {
  id              String          @id @default(uuid()) @db.Char(36)
  cargoId         String          @db.Char(36)
  truckId         String?         @db.Char(36)
  trailerId       String?         @db.Char(36)
  driverId        String?         @db.Char(36)
  departureDate   DateTime?
  arrivalEstimate DateTime?
  arrivalDate     DateTime?
  loadedDate      DateTime?
  dischargeDate   DateTime?
  currentStatus   TripStatus      @default(WAITING_APPOINTMENT)
  currentPosition String?         @db.VarChar(150)
  tonnage         Decimal?        @db.Decimal(12, 3)
  transporterName String?         @db.VarChar(150)
  isSubcontracted Boolean         @default(false)
  dispatchedBy    String?         @db.VarChar(150)
  remarks         String?         @db.Text
  horsePlate      String?         @db.VarChar(30)
  trailerPlate    String?         @db.VarChar(30)
  driverName      String?         @db.VarChar(150)
  driverPassport  String?         @db.VarChar(30)
  driverLicense   String?         @db.VarChar(80)
  driverPhone     String?         @db.VarChar(30)
  bookingReference String?        @db.VarChar(80)
  trackingToken   String          @unique @default(uuid()) @db.Char(36)
  cargo           Cargo           @relation(fields: [cargoId], references: [id], onDelete: Restrict)
  truck           Truck?          @relation(fields: [truckId], references: [id], onDelete: Restrict)
  trailer         Trailer?        @relation(fields: [trailerId], references: [id], onDelete: Restrict)
  driver          Driver?         @relation(fields: [driverId], references: [id], onDelete: Restrict)
  trackingPoints  TrackingPoint[]
  deliveries      Delivery[]
  incidents       Incident[]
  events          TripEvent[]
  borders         TripBorder[]
  containerReturn ContainerReturn?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([cargoId])
  @@index([truckId])
  @@index([trailerId])
  @@index([driverId])
  @@index([currentStatus])
  @@index([createdAt])
  @@map("trips")
}

model ContainerReturn {
  id           String    @id @default(uuid()) @db.Char(36)
  tripId       String    @unique @db.Char(36)
  returnedTo   String?   @db.VarChar(150)
  receiverName String?   @db.VarChar(150)
  podDocument  String?   @db.MediumText
  returnedAt   DateTime?
  observations String?   @db.Text
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([returnedAt])
  @@map("container_returns")
}

model TripEvent {
  id         String        @id @default(uuid()) @db.Char(36)
  tripId     String        @db.Char(36)
  type       TripEventType
  occurredAt DateTime
  fromStatus TripStatus?
  toStatus   TripStatus?
  note       String?
  createdBy  String?       @db.Char(36)
  createdAt  DateTime      @default(now())
  trip       Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, occurredAt])
  @@map("trip_events")
}

model TrackingPoint {
  id         String   @id @default(uuid()) @db.Char(36)
  tripId     String   @db.Char(36)
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  speed      Decimal? @db.Decimal(8, 2)
  heading    Decimal? @db.Decimal(6, 2)
  accuracy   Decimal? @db.Decimal(8, 2)
  recordedAt DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tripId])
  // histórico/última posição filtram por viagem e ordenam por data — o
  // índice composto evita o filesort na tabela que mais cresce
  @@index([tripId, recordedAt])
  @@index([recordedAt])
  @@index([createdAt])
  @@map("tracking_points")
}

model Delivery {
  id               String    @id @default(uuid()) @db.Char(36)
  tripId           String    @db.Char(36)
  receiverName     String?   @db.VarChar(150)
  receiverDocument String?   @db.VarChar(80)
  deliveryPhoto    String?   @db.MediumText
  signature        String?   @db.MediumText
  podDocument      String?   @db.MediumText
  deliveredAt      DateTime?
  observations     String?   @db.Text
  trip             Trip      @relation(fields: [tripId], references: [id], onDelete: Restrict)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tripId])
  @@index([deliveredAt])
  @@index([createdAt])
  @@map("deliveries")
}

model Incident {
  id          String       @id @default(uuid()) @db.Char(36)
  tripId      String       @db.Char(36)
  type        IncidentType
  description String?      @db.Text
  latitude    Decimal?     @db.Decimal(10, 7)
  longitude   Decimal?     @db.Decimal(10, 7)
  photo       String?      @db.MediumText
  reportedAt  DateTime     @default(now())
  resolvedAt  DateTime?
  trip        Trip         @relation(fields: [tripId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tripId])
  @@index([type])
  @@index([reportedAt])
  @@index([resolvedAt])
  @@index([createdAt])
  @@map("incidents")
}

model Notification {
  id        String           @id @default(uuid()) @db.Char(36)
  userId    String           @db.Char(36)
  title     String           @db.VarChar(150)
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
